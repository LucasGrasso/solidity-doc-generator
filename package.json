{
  "name": "solidity-doc-generator",
  "version": "1.2.1",
  "description": "Modular, markdown-based documentation generator for Solidity contracts. Output clean markdown with YAML frontmatter, compatible with any static site generator.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "solidity-docgen": "./bin/solidity-docgen"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/schema.js",
      "types": "./dist/config/schema.d.ts"
    },
    "./templates": {
      "import": "./dist/templates/handlebars.js",
      "types": "./dist/templates/handlebars.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    },
    "./hardhat": {
      "import": "./dist/hardhat/index.js",
      "types": "./dist/hardhat/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docgen": "ts-node src/cli/index.ts",
    "prepare": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "solidity",
    "documentation",
    "generator",
    "markdown",
    "ast",
    "contracts",
    "ethereum",
    "hardhat"
  ],
  "author": "Lucas Grasso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LucasGrasso/solidity-doc-generator"
  },
  "bugs": {
    "url": "https://github.com/LucasGrasso/solidity-doc-generator/issues"
  },
  "homepage": "https://github.com/LucasGrasso/solidity-doc-generator#readme",
  "dependencies": {
    "handlebars": "^4.7.9",
    "markdown-it-mathjax3": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4",
    "vue": "^3.5.31"
  }
}
